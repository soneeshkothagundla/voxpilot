# =============================================================================
# VoxPilot secrets. Copy this file to ".env" and fill in real values.
# NEVER commit your real .env — it is gitignored.
# =============================================================================

# ----- Amazon Bedrock (default provider) -------------------------------------
# A Bedrock API key (bearer token). Generate one in the AWS console:
#   Bedrock -> API keys -> Generate long-term API key
# The app reads this automatically; it is also what boto3 uses for bearer auth.
AWS_BEARER_TOKEN_BEDROCK=

# AWS region your Bedrock models / inference profiles live in.
AWS_REGION=us-east-1

# ----- First-party Anthropic API (alternative provider) ----------------------
# Only needed if you set agent.provider: anthropic in config.yaml
ANTHROPIC_API_KEY=

# ----- OpenAI Whisper API (optional STT backend) -----------------------------
# Only needed if you set stt.backend: openai in config.yaml
OPENAI_API_KEY=
